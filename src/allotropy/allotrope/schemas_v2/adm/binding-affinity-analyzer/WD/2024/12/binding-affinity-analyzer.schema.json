{
  "$id": "http://purl.allotrope.org/json-schemas/adm/binding-affinity-analyzer/WD/2024/12/binding-affinity-analyzer.schema",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "properties": {
        "binding affinity analyzer aggregate document": {
          "allOf": [
            {
              "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/hierarchy.schema#/$defs/techniqueAggregateDocument"
            },
            {
              "$asm.property-class": "TODO",
              "type": "object",
              "properties": {
                "device system document": {
                  "required": [
                    "device identifier",
                    "model number"
                  ]
                },
                "binding affinity analyzer document": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/hierarchy.schema#/$defs/techniqueDocument"
                      },
                      {
                        "type": "object",
                        "$asm.property-class": "TODO",
                        "properties": {
                          "measurement aggregate document": {
                            "type": "object",
                            "properties": {
                              "measurement time": {
                                "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0000952",
                                "$asm.pattern": "value datum",
                                "$asm.type": "http://www.w3.org/2001/XMLSchema#dateTimeStamp",
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tDateTimeStampValue"
                              },
                              "experiment type": {
                                "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002229",
                                "$asm.pattern": "value datum",
                                "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                              },
                              "analytical method identifier": {
                                "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001978",
                                "$asm.pattern": "value datum",
                                "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                              },
                              "compartment temperature": {
                                "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002549",
                                "$asm.pattern": "quantity datum",
                                "allOf": [
                                  {
                                    "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                  },
                                  {
                                    "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/degC"
                                  }
                                ]
                              },
                              "measurement document": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "allOf": [
                                    {
                                      "required": [
                                        "measurement identifier"
                                      ],
                                      "properties": {
                                        "POSIX path": {
                                          "$asm.pattern": "binary datum",
                                          "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001928",
                                          "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                          "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                        },
                                        "identifier": {
                                          "$asm.pattern": "value datum",
                                          "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0000917",
                                          "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                          "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                        },
                                        "sample document": {
                                          "properties": {
                                            "location identifier": {
                                              "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002844",
                                              "$asm.pattern": "value datum",
                                              "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                              "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                            },
                                            "well plate identifier": {
                                              "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002888",
                                              "$asm.pattern": "value datum",
                                              "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                              "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                            },
                                            "concentration": {
                                              "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002036",
                                              "$asm.pattern": "quantity datum",
                                              "allOf": [
                                                {
                                                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                },
                                                {
                                                  "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/nM"
                                                }
                                              ]
                                            }
                                          }
                                        },
                                        "device control aggregate document": {
                                          "properties": {
                                            "device control document": {
                                              "items": {
                                                "allOf": [
                                                  {
                                                    "properties": {
                                                      "sample volume setting": {
                                                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002492",
                                                        "$asm.pattern": "quantity datum",
                                                        "allOf": [
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                          },
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/\u03bcL"
                                                          }
                                                        ]
                                                      },
                                                      "sample temperature setting": {
                                                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002148",
                                                        "$asm.pattern": "quantity datum",
                                                        "allOf": [
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                          },
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/degC"
                                                          }
                                                        ]
                                                      }
                                                    }
                                                  },
                                                  {
                                                    "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/orderedItem"
                                                  }
                                                ]
                                              },
                                              "minItems": 1
                                            }
                                          }
                                        },
                                        "processed data aggregate document": {
                                          "properties": {
                                            "processed data document": {
                                              "items": {
                                                "properties": {
                                                  "POSIX path": {
                                                    "$asm.pattern": "binary datum",
                                                    "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001928",
                                                    "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                                    "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                                  },
                                                  "identifier": {
                                                    "$asm.pattern": "value datum",
                                                    "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0000917",
                                                    "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                                    "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                                  },
                                                  "binding on rate measurement datum (kon)": {
                                                    "$asm.property-class": "http://purl.obolibrary.org/obo/OBI_0001605",
                                                    "$asm.pattern": "quantity datum",
                                                    "allOf": [
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                      },
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/M-1s-1"
                                                      }
                                                    ]
                                                  },
                                                  "binding off rate measurement datum (koff)": {
                                                    "$asm.property-class": "http://purl.obolibrary.org/obo/OBI_0001603",
                                                    "$asm.pattern": "quantity datum",
                                                    "allOf": [
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                      },
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/s^-1"
                                                      }
                                                    ]
                                                  },
                                                  "equilibrium dissociation constant (KD)": {
                                                    "$asm.property-class": "http://purl.obolibrary.org/obo/OBI_0001536",
                                                    "$asm.pattern": "quantity datum",
                                                    "allOf": [
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                      },
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/M"
                                                      }
                                                    ]
                                                  },
                                                  "maximum binding capacity (Rmax)": {
                                                    "$asm.property-class": "TODO",
                                                    "$asm.pattern": "quantity datum",
                                                    "allOf": [
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                                      },
                                                      {
                                                        "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/RU"
                                                      }
                                                    ]
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    },
                                    {
                                      "anyOf": [
                                        {
                                          "$ref": "http://purl.allotrope.org/json-schemas/adm/surface-plasmon-resonance/WD/2024/12/surface-plasmon-resonance-binding-assay.schema#/$defs/measurementDocumentItems"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                "minItems": 1
                              }
                            },
                            "required": [
                              "measurement time"
                            ]
                          }
                        }
                      }
                    ]
                  }
                }
              },
              "required": [
                "binding affinity analyzer document"
              ]
            }
          ]
        }
      }
    }
  ],
  "required": [
    "$asm.manifest"
  ],
  "$defs": {
    "http://purl.allotrope.org/json-schemas/adm/surface-plasmon-resonance/WD/2024/12/surface-plasmon-resonance-binding-assay.schema": {
      "$id": "http://purl.allotrope.org/json-schemas/adm/surface-plasmon-resonance/WD/2024/12/surface-plasmon-resonance-binding-assay.schema",
      "$defs": {
        "measurementDocumentItems": {
          "properties": {
            "method name": {
              "$asm.pattern": "value datum",
              "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001606",
              "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
              "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
            },
            "ligand identifier": {
              "$asm.pattern": "value datum",
              "$asm.property-class": "TODO",
              "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
              "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
            },
            "device control aggregate document": {
              "type": "object",
              "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002722",
              "$asm.pattern": "aggregate datum",
              "properties": {
                "device control document": {
                  "type": "array",
                  "$asm.array-ordered": true,
                  "$asm.array-mixed": false,
                  "$asm.pattern": "indexed datum",
                  "items": {
                    "allOf": [
                      {
                        "type": "object",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002723",
                        "$asm.pattern": "aggregate datum",
                        "properties": {
                          "flow cell identifier": {
                            "$asm.pattern": "value datum",
                            "$asm.property-class": "TODO",
                            "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                          },
                          "flow rate": {
                            "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001881",
                            "$asm.pattern": "quantity datum",
                            "allOf": [
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                              },
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/\u00b5L~1min"
                              }
                            ]
                          },
                          "contact time": {
                            "$asm.property-class": "TODO",
                            "$asm.pattern": "quantity datum",
                            "allOf": [
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                              },
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/s"
                              }
                            ]
                          },
                          "dilution factor": {
                            "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002758",
                            "$asm.pattern": "quantity datum",
                            "allOf": [
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                              },
                              {
                                "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/%"
                              }
                            ]
                          },
                          "flow path": {
                            "$asm.pattern": "value datum",
                            "$asm.property-class": "TODO",
                            "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                          }
                        }
                      }
                    ]
                  },
                  "minItems": 1
                }
              }
            },
            "sensorgram data cube": {
              "$asm.property-class": "TODO",
              "$asm.pattern": "datacube",
              "type": "object",
              "allOf": [
                {
                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/cube.schema#/$defs/tDatacube"
                },
                {
                  "properties": {
                    "cube-structure": {
                      "properties": {
                        "dimensions": {
                          "minItems": 1,
                          "maxItems": 1,
                          "prefixItems": [
                            {
                              "oneOf": [
                                {
                                  "properties": {
                                    "concept": {
                                      "const": "elapsed time"
                                    },
                                    "unit": {
                                      "const": "s"
                                    },
                                    "@componentDatatype": {
                                      "const": "double"
                                    }
                                  }
                                }
                              ]
                            }
                          ]
                        },
                        "measures": {
                          "minItems": 1,
                          "maxItems": 1,
                          "contains": {
                            "oneOf": [
                              {
                                "properties": {
                                  "concept": {
                                    "const": "resonance"
                                  },
                                  "unit": {
                                    "const": "RU"
                                  },
                                  "@componentDatatype": {
                                    "const": "double"
                                  }
                                }
                              }
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              ]
            },
            "sensor chip document": {
              "$asm.property-class": "TODO",
              "$asm.pattern": "aggregate datum",
              "type": "object",
              "required": [
                "sensor chip identifier"
              ],
              "properties": {
                "sensor chip identifier": {
                  "$asm.pattern": "value datum",
                  "$asm.property-class": "TODO",
                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                },
                "sensor chip type": {
                  "$asm.pattern": "value datum",
                  "$asm.property-class": "TODO",
                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                },
                "product manufacturer": {
                  "$asm.pattern": "value datum",
                  "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0001258",
                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                },
                "lot number": {
                  "$asm.pattern": "value datum",
                  "$asm.property-class": "http://purl.obolibrary.org/obo/IAO_0000132",
                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                },
                "custom information aggregate document": {
                  "allOf": [
                    {
                      "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/hierarchy.schema#/$defs/customInformationAggregateDocument"
                    }
                  ]
                }
              }
            },
            "processed data aggregate document": {
              "properties": {
                "processed data document": {
                  "items": {
                    "properties": {
                      "report point aggregate document": {
                        "properties": {
                          "report point document": {
                            "items": {
                              "properties": {
                                "absolute resonance": {
                                  "$asm.property-class": "TODO",
                                  "$asm.pattern": "quantity datum",
                                  "allOf": [
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                    },
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/RU"
                                    }
                                  ]
                                },
                                "report point identifier": {
                                  "$asm.pattern": "value datum",
                                  "$asm.property-class": "TODO",
                                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                },
                                "identifier role": {
                                  "$asm.pattern": "value datum",
                                  "$asm.property-class": "http://purl.allotrope.org/ontologies/role#AFRL_0000007",
                                  "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                                  "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tStringValue"
                                },
                                "relative resonance": {
                                  "$asm.property-class": "TODO",
                                  "$asm.pattern": "quantity datum",
                                  "allOf": [
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                    },
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/RU"
                                    }
                                  ]
                                },
                                "time setting": {
                                  "$asm.pattern": "quantity datum",
                                  "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002288",
                                  "allOf": [
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/09/core.schema#/$defs/tQuantityValue"
                                    },
                                    {
                                      "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2025/03/units.schema#/$defs/s"
                                    }
                                  ]
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
