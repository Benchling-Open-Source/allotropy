{
  "$defs": {
    "measurementDocumentItems": {
      "properties": {
        "device control aggregate document": {
          "properties": {
            "device control document": {
              "items": {
                "allOf": [
                  {
                    "properties": {
                      "auto focus enabled setting": {
                        "$asm.pattern": "boolean datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0003074",
                        "$asm.type": "http://www.w3.org/2001/XMLSchema#boolean",
                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tBooleanValue"
                      },
                      "detector wavelength setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002456",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/nm"
                          }
                        ]
                      },
                      "excitation wavelength setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002479",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/nm"
                          }
                        ]
                      },
                      "exposure duration setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002862",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/ms"
                          }
                        ]
                      },
                      "fluorescent tag setting": {
                        "$asm.pattern": "value datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002870",
                        "$asm.type": "http://www.w3.org/2001/XMLSchema#string",
                        "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tStringValue"
                      },
                      "illumination setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002861",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/%25"
                          }
                        ]
                      },
                      "image count setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002932",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/(unitless)"
                          }
                        ]
                      },
                      "magnification setting": {
                        "$asm.pattern": "quantity datum",
                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002226",
                        "allOf": [
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                          },
                          {
                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/(unitless)"
                          }
                        ]
                      }
                    },
                    "required": [
                      "fluorescent tag setting"
                    ]
                  }
                ]
              }
            }
          }
        }
      },
      "required": [
        "image aggregate document"
      ]
    }
  },
  "$id": "http://purl.allotrope.org/json-schemas/adm/fluorescence/REC/2026/03/fluorescence-imaging-point-detector.schema",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}