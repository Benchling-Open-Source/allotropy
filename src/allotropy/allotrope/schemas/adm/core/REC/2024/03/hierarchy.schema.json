{
  "$id": "http://purl.allotrope.org/json-schemas/adm/core/REC/2024/03/hierarchy.schema",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Common hierarchy schema defs.",
  "$defs": {
