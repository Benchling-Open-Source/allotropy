                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                                                          },
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/%C2%B5m"
                                                          }
                                                        ]
                                                      },
                                                      "minimum cell diameter setting": {
                                                        "$asm.pattern": "quantity datum",
                                                        "$asm.property-class": "http://purl.allotrope.org/ontologies/result#AFR_0002863",
                                                        "allOf": [
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/adm/core/REC/2026/03/core.schema#/$defs/tQuantityValue"
                                                          },
                                                          {
                                                            "$ref": "http://purl.allotrope.org/json-schemas/qudt/REC/2026/03/units.schema#/$defs/%C2%B5m"
